{
  "manifest_version": 3,
  "name": "Flagged AI - Job Scam Checker",
  "version": "0.1.0",
  "description": "Send job posts to Flagged AI and get a risk verdict.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://localhost:3000/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
